{
   "Version":"2012-10-17",
   "Statement":[
      {
         "Effect":"Allow",
         "Action":[
            "s3:GetBucketLocation",
            "s3:GetObject",
            "s3:ListBucket"
         ],
         "Resource":[
            "arn:aws:s3:::fcj-vmimport-vonhat",
            "arn:aws:s3:::fcj-vmimport-vonhat/*"
         ]
      },
      {
         "Effect":"Allow",
         "Action":[
            "ec2:ModifyInstanceAttribute",
            "ec2:CopyImage",
            "ec2:RegisterImage",
            "ec2:Describe*"
         ],
         "Resource":"*"
      }
   ]
}
